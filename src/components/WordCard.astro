---
import type { DisplayWord } from "../lib/lastWords";
import { formatRussianDate } from "../lib/dates";
import { getTagHref } from "../lib/tags";

type Props = {
  word: DisplayWord;
  tagSlugs?: Record<string, string>;
};

const { word, tagSlugs = {} } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const place = word.city ?? word.country ?? "Место не заполнено";
const countryPeriod = word.country && word.period ? `${word.country}: ${word.period}` : word.country ?? word.period;
const publishedDate = formatRussianDate(word.date);
const statementDate = word.statementDate ? formatRussianDate(word.statementDate) : undefined;
---

<div
  class="word-card"
  data-word-card
  data-person={word.person.toLowerCase()}
  data-case={word.caseName.toLowerCase()}
  data-city={place}
  data-date={word.date}
  data-title={word.title.toLowerCase()}
  data-text={word.text.toLowerCase()}
>
  <div>
    <h3>
      <a class="word-card-link" href={`${base}words/${word.slug}/`}>{word.title}</a>
    </h3>
    <p>{word.caseName}</p>
    <div class="tag-row">
      {word.tags.map((tag) => (
        <a class="tag" href={getTagHref(base, tagSlugs[tag] ?? "tag")}>{tag}</a>
      ))}
    </div>
  </div>
  <div class="word-card-side">
    <time class="published-date" datetime={word.date}>Опубликовано {publishedDate}</time>
    <p class="meta">
      {countryPeriod}
      {statementDate && <><br />Дата слова: {statementDate}</>}
      {word.readingTime && <><br />Время чтения: {word.readingTime}</>}
    </p>
  </div>
</div>

<style>
  .word-card-link {
    color: var(--accent);
    text-underline-offset: 3px;
  }

  .word-card-link:visited {
    color: var(--visited);
  }

  .word-card-link:hover {
    color: var(--accent);
    text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
  }

  .word-card-link:visited:hover {
    color: var(--visited);
    text-decoration-color: color-mix(in srgb, var(--visited) 45%, transparent);
  }

  .word-card-side {
    display: grid;
    gap: 14px;
    align-self: stretch;
    justify-items: end;
  }

  .published-date {
    color: var(--muted);
    font-size: 12px;
    line-height: 1.2;
    white-space: nowrap;
  }

  .word-card-side .meta {
    align-self: end;
    text-align: right;
  }

  @media (max-width: 860px) {
    .word-card-side {
      justify-items: start;
    }

    .word-card-side .meta {
      text-align: left;
    }
  }
</style>
