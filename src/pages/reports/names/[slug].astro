---
import { getCollection } from "astro:content";
import WordCard from "../../../components/WordCard.astro";
import ReferencePageLayout from "../../../components/ReferencePageLayout.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { toDisplayWord, type DisplayWord } from "../../../lib/lastWords";
import { buildPersonDirectory } from "../../../lib/people";
import { buildTagDirectory } from "../../../lib/tags";

type Props = {
    person: {
        name: string;
        slug: string;
        count: number;
        words: DisplayWord[];
    };
    tagSlugs: Record<string, string>;
};

export async function getStaticPaths() {
    const words = (await getCollection("last-words")).map(toDisplayWord);
    const people = buildPersonDirectory(words);
    const tagSlugs = Object.fromEntries(
        buildTagDirectory(words).map((tag) => [tag.name, tag.slug]),
    );

    return people.map((person) => ({
        params: { slug: person.slug },
        props: { person, tagSlugs },
    }));
}

const { person, tagSlugs } = Astro.props as Props;
const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;

function formatCountLabel(count: number) {
    const mod10 = count % 10;
    const mod100 = count % 100;

    if (mod10 === 1 && mod100 !== 11) {
        return "запись";
    }

    if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) {
        return "записи";
    }

    return "записей";
}
---

<BaseLayout title={person.name}>
    <ReferencePageLayout current="names">
        <section>
            <h1>{person.name}</h1>
            <p class="meta">
                {person.count} {formatCountLabel(person.count)}
            </p>
        </section>

        <section class="section">
            <div class="button-row person-back-row">
                <a class="button secondary" href={`${base}reports/names/`}
                    >Ко всем именам</a
                >
            </div>
            <div class="word-list">
                {
                    person.words.map((word) => (
                        <WordCard word={word} tagSlugs={tagSlugs} />
                    ))
                }
            </div>
        </section>
    </ReferencePageLayout>
</BaseLayout>

<style>
    .person-back-row {
        margin-bottom: 24px;
    }
</style>
