---
import { getCollection } from "astro:content";
import ReferencePageLayout from "../../components/ReferencePageLayout.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { toDisplayWord } from "../../lib/lastWords";
import { buildPersonDirectory, getPersonHref } from "../../lib/people";

const people = buildPersonDirectory(
    (await getCollection("last-words")).map(toDisplayWord),
);

const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Все имена">
    <ReferencePageLayout current="names">
        <section class="names-section">
            <div class="names-tools">
                <input id="names-search" type="search" placeholder="Найти имя" />
                <p class="meta">
                    <span id="names-count">{people.length}</span> из {people.length} имен
                </p>
            </div>

            <div class="names-list">
                {
                    people.map((person) => (
                        <span class="name-item">
                            <a href={getPersonHref(base, person.slug)}>
                                {person.name}
                            </a>
                            {person.count > 1 && (
                                <span class="name-count">({person.count})</span>
                            )}
                        </span>
                    ))
                }
            </div>
        </section>

        <script>
            const searchInput = document.querySelector("#names-search");
            const countNode = document.querySelector("#names-count");
            const nameItems = Array.from(document.querySelectorAll(".name-item"));

            function applySearch() {
                if (!(searchInput instanceof HTMLInputElement)) {
                    return;
                }

                const query = searchInput.value.trim().toLowerCase();
                let visibleCount = 0;

                for (const item of nameItems) {
                    const text = item.textContent?.toLowerCase() ?? "";
                    const matchesSearch =
                        query.length === 0 || text.includes(query);
                    const isVisible = matchesSearch;
                    item.toggleAttribute("hidden", !isVisible);
                    visibleCount += isVisible ? 1 : 0;
                }

                if (countNode) {
                    countNode.textContent = String(visibleCount);
                }
            }

            searchInput?.addEventListener("input", applySearch);
            applySearch();
        </script>
    </ReferencePageLayout>
</BaseLayout>

<style>
    .names-section {
        max-width: none;
    }

    .names-tools {
        display: grid;
        grid-template-columns: minmax(220px, 420px) auto;
        align-items: center;
        gap: 16px;
        margin-top: 24px;
    }

    .names-tools input {
        max-width: none;
    }

    .names-list {
        column-count: 3;
        column-gap: 30px;
        margin-top: 18px;
    }

    .name-item {
        display: block;
        break-inside: avoid;
        padding: 4px 0;
        line-height: 1.35;
    }

    .name-item a {
        color: var(--accent);
        font-size: 14px;
        text-underline-offset: 3px;
    }

    .name-item a:visited {
        color: var(--visited);
    }

    .name-count {
        display: inline-block;
        margin-left: 5px;
        color: color-mix(in srgb, var(--muted) 70%, var(--background));
        font-size: 10px;
        font-weight: 400;
        line-height: 1;
        vertical-align: baseline;
    }

    .name-item a:hover {
        color: var(--accent);
        text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
    }

    .name-item a:visited:hover {
        color: var(--visited);
        text-decoration-color: color-mix(in srgb, var(--visited) 45%, transparent);
    }

    .name-item[hidden] {
        display: none;
    }

    @media (max-width: 900px) {
        .names-list {
            column-count: 2;
        }
    }

    @media (max-width: 640px) {
        .names-tools {
            align-items: flex-start;
            grid-template-columns: 1fr;
        }

        .names-tools input {
            max-width: none;
        }

        .names-list {
            column-count: 1;
        }
    }
</style>
