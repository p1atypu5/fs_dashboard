---
import { getCollection } from "astro:content";
import { toDisplayWord } from "../../lib/lastWords";
import { buildTagDirectory, getTagHref, isRussianTag } from "../../lib/tags";
import ReferencePageLayout from "../../components/ReferencePageLayout.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const tags = buildTagDirectory(
    (await getCollection("last-words"))
        .map(toDisplayWord)
        .filter((word) => word.language === "ru"),
).filter((tag) => isRussianTag(tag.name));
const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Библиотека тегов">
    <ReferencePageLayout current="tags">
        <section class="tags-section">
            <div class="tags-tools">
                <input id="tags-search" type="search" placeholder="Найти тег" />
                <p class="meta">
                    <span id="tags-count">{tags.length}</span> из {tags.length} тегов
                </p>
            </div>

            <div class="tags-list" id="tags-list">
                {
                    tags.map((tag) => (
                        <div class="tag-item">
                            <a href={getTagHref(base, tag.slug)}>{tag.name}</a>
                            <small>{tag.count}</small>
                        </div>
                    ))
                }
            </div>
        </section>

        <script>
            const searchInput = document.querySelector("#tags-search");
            const countNode = document.querySelector("#tags-count");
            const tagItems = Array.from(document.querySelectorAll(".tag-item"));

            function applySearch() {
                if (!(searchInput instanceof HTMLInputElement)) {
                    return;
                }

                const query = searchInput.value.trim().toLowerCase();
                let visibleCount = 0;

                for (const item of tagItems) {
                    const text = item.textContent?.toLowerCase() ?? "";
                    const matchesSearch =
                        query.length === 0 || text.includes(query);
                    const isVisible = matchesSearch;
                    item.toggleAttribute("hidden", !isVisible);
                    visibleCount += isVisible ? 1 : 0;
                }

                if (countNode) {
                    countNode.textContent = String(visibleCount);
                }
            }

            searchInput?.addEventListener("input", applySearch);
            applySearch();
        </script>
    </ReferencePageLayout>
</BaseLayout>

<style>
    .tags-section {
        max-width: none;
    }

    .tags-tools {
        display: grid;
        grid-template-columns: minmax(220px, 420px) auto;
        align-items: center;
        gap: 16px;
        margin-top: 24px;
    }

    .tags-tools input {
        max-width: none;
    }

    .tags-list {
        column-count: 3;
        column-gap: 30px;
        margin-top: 18px;
    }

    .tag-item {
        display: flex;
        break-inside: avoid;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        padding: 4px 0;
        color: var(--text);
        font-size: 14px;
        line-height: 1.35;
    }

    .tag-item a {
        color: var(--accent);
        text-underline-offset: 3px;
    }

    .tag-item a:visited {
        color: var(--visited);
    }

    .tag-item a:hover {
        color: var(--accent);
        text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
    }

    .tag-item a:visited:hover {
        color: var(--visited);
        text-decoration-color: color-mix(in srgb, var(--visited) 45%, transparent);
    }

    .tag-item small {
        flex: 0 0 auto;
        color: var(--muted);
        font-size: 12px;
    }

    .tag-item[hidden] {
        display: none;
    }

    @media (max-width: 900px) {
        .tags-list {
            column-count: 2;
        }
    }

    @media (max-width: 640px) {
        .tags-tools {
            align-items: flex-start;
            grid-template-columns: 1fr;
        }

        .tags-tools input {
            max-width: none;
        }

        .tags-list {
            column-count: 1;
        }
    }
</style>
