---
import { getCollection } from "astro:content";
import WordCard from "../components/WordCard.astro";
import { sortWordsByDate, toDisplayWord } from "../lib/lastWords";
import BaseLayout from "../layouts/BaseLayout.astro";
import wpExportMeta from "../data/wpExportMeta.json";

const finalWords = (await getCollection("last-words")).map(toDisplayWord);
const wordsByDate = sortWordsByDate(finalWords);
const peopleCount = new Set(finalWords.map((word) => word.person)).size;
const countriesCount = new Set(
    finalWords.map((word) => word.country).filter(Boolean),
).size;
const dayMs = 24 * 60 * 60 * 1000;
const syncTimeZone = wpExportMeta.timeZone || "UTC";
const syncDateParts = getDatePartsInTimeZone(
    new Date(wpExportMeta.fetchedAt),
    syncTimeZone,
);
const syncDayUtc = syncDateParts
    ? Date.UTC(syncDateParts.year, syncDateParts.month - 1, syncDateParts.day)
    : 0;
const periodStart = syncDayUtc
    ? new Date(syncDayUtc - 7 * dayMs)
    : undefined;
const periodEnd = syncDayUtc ? new Date(syncDayUtc - dayMs) : undefined;
const periodStartKey = periodStart ? toDateKey(periodStart) : "";
const periodEndKey = periodEnd ? toDateKey(periodEnd) : "";
const latestWords = wordsByDate.filter((word) => {
    const dateKey = word.date.slice(0, 10);
    return dateKey >= periodStartKey && dateKey <= periodEndKey;
});
const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;

const dateFormatter = new Intl.DateTimeFormat("ru-RU", {
    day: "numeric",
    month: "long",
    year: "numeric",
});

function formatCountLabel(count: number, forms: [string, string, string]) {
    const mod10 = count % 10;
    const mod100 = count % 100;

    if (mod10 === 1 && mod100 !== 11) {
        return forms[0];
    }

    if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) {
        return forms[1];
    }

    return forms[2];
}

function formatDateRange(start?: Date, end?: Date) {
    if (!start || !end) {
        return "";
    }

    return `${dateFormatter.format(start)} - ${dateFormatter.format(end)}`;
}

function getDatePartsInTimeZone(date: Date, timeZone: string) {
    if (Number.isNaN(date.getTime())) {
        return undefined;
    }

    const parts = new Intl.DateTimeFormat("en-CA", {
        day: "2-digit",
        month: "2-digit",
        timeZone,
        year: "numeric",
    }).formatToParts(date);

    const values = Object.fromEntries(
        parts
            .filter((part) => part.type !== "literal")
            .map((part) => [part.type, Number(part.value)]),
    );

    if (!values.year || !values.month || !values.day) {
        return undefined;
    }

    return {
        year: values.year,
        month: values.month,
        day: values.day,
    };
}

function toDateKey(date: Date) {
    return date.toISOString().slice(0, 10);
}
---

<BaseLayout title="Последнее слово">
    <section>
        <h1>Readonly-зеркало последних слов</h1>
        <div class="button-row">
            <a class="button" href={`${base}words/`}>Открыть базу слов</a>
            <a class="button secondary" href={`${base}about/`}
                >Как это устроено</a
            >
        </div>
    </section>

    <section class="stats-grid" aria-label="Сводка по базе">
        <div class="stat">
            <strong>{finalWords.length}</strong>
            <span
                >{
                    formatCountLabel(finalWords.length, [
                        "слово",
                        "слова",
                        "слов",
                    ])
                }</span
            >
        </div>
        <div class="stat">
            <strong>{peopleCount}</strong>
            <span
                >{
                    formatCountLabel(peopleCount, [
                        "человек",
                        "человека",
                        "человек",
                    ])
                }</span
            >
        </div>
        <div class="stat">
            <strong>{countriesCount}</strong>
            <span
                >{
                    formatCountLabel(countriesCount, [
                        "страна",
                        "страны",
                        "стран",
                    ])
                }</span
            >
        </div>
    </section>

    <section class="section">
        <h2>
            Последние добавления за неделю
            <span class="heading-period"
                >({formatDateRange(periodStart, periodEnd)})</span
            >
        </h2>
        <div class="word-list">
            {latestWords.map((word) => <WordCard word={word} />)}
        </div>
    </section>
</BaseLayout>

<style>
    .heading-period {
        color: var(--muted);
        font-size: 0.55em;
        font-weight: 500;
        white-space: nowrap;
    }
</style>
