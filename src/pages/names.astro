---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const entries = await getCollection("last-words");
const names = entries
  .map((entry) => ({
    name: entry.data.person,
    slug: entry.data.localSlug,
  }))
  .sort((a, b) => a.name.localeCompare(b.name, "ru"));

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Все имена">
  <section>
    <h1>Все имена</h1>
    <p class="lead">
      Экспериментальная страница для ощущения масштаба базы: все имена одним плотным списком.
    </p>
  </section>

  <section class="section names-section">
    <p class="meta">{names.length} записей</p>
    <div class="names-list">
      {names.map((item) => <a href={`${base}words/${item.slug}/`}>{item.name}</a>)}
    </div>
  </section>
</BaseLayout>

<style>
  .names-section {
    max-width: none;
  }

  .names-list {
    column-count: 3;
    column-gap: 30px;
    margin-top: 18px;
  }

  .names-list a {
    display: block;
    break-inside: avoid;
    padding: 4px 0;
    color: var(--text);
    font-size: 14px;
    line-height: 1.35;
    text-decoration-color: var(--line);
    text-underline-offset: 3px;
  }

  .names-list a:hover {
    color: var(--accent-strong);
    text-decoration-color: var(--accent-strong);
  }

  @media (max-width: 900px) {
    .names-list {
      column-count: 2;
    }
  }

  @media (max-width: 640px) {
    .names-list {
      column-count: 1;
    }
  }
</style>
