---
import { getCollection } from "astro:content";
import WordCard from "../../components/WordCard.astro";
import { sortWordsByDate, toDisplayWord } from "../../lib/lastWords";
import BaseLayout from "../../layouts/BaseLayout.astro";

const finalWords = (await getCollection("last-words")).map(toDisplayWord);
const wordsByDate = sortWordsByDate(finalWords);
const places = [...new Set(finalWords.map((word) => word.city ?? word.country).filter(Boolean))].sort((a, b) =>
  a.localeCompare(b, "ru"),
);
---

<BaseLayout title="База слов">
  <section>
    <h1>База слов</h1>
    <p class="lead">
      Все записи из зеркала в одном месте. Поиск и фильтры работают в браузере, без правки данных
      и без доступа к админке WordPress.
    </p>
  </section>

  <section class="section" aria-label="Фильтры базы слов">
    <div class="toolbar">
      <input id="word-search" type="search" placeholder="Поиск по имени, делу или тексту" />
      <select id="city-filter" aria-label="Фильтр по городу">
        <option value="">Все места</option>
        {places.map((place) => <option value={place}>{place}</option>)}
      </select>
      <select id="sort-order" aria-label="Сортировка">
        <option value="date-desc">Сначала новые</option>
        <option value="date-asc">Сначала старые</option>
        <option value="person-asc">По имени А-Я</option>
      </select>
    </div>
    <p class="meta">Поиск, фильтры и сортировка пока не работают стабильно.</p>

    <p class="meta"><span id="visible-count">{finalWords.length}</span> из {finalWords.length} записей</p>
    <div id="word-list" class="word-list">
      {wordsByDate.map((word) => <WordCard word={word} />)}
    </div>
    <p id="empty-state" class="empty-state">Ничего не найдено. Попробуйте изменить запрос или фильтр.</p>
  </section>

  <script>
    const searchInput = document.querySelector("#word-search");
    const cityFilter = document.querySelector("#city-filter");
    const sortOrder = document.querySelector("#sort-order");
    const list = document.querySelector("#word-list");
    const visibleCount = document.querySelector("#visible-count");
    const emptyState = document.querySelector("#empty-state");
    const cards = Array.from(document.querySelectorAll("[data-word-card]"));

    function applyFilters() {
      if (!(searchInput instanceof HTMLInputElement) || !(cityFilter instanceof HTMLSelectElement)) {
        return;
      }

      const query = searchInput.value.trim().toLowerCase();
      const city = cityFilter.value;
      let shown = 0;

      for (const card of cards) {
        if (!(card instanceof HTMLElement)) {
          continue;
        }

        const haystack = [
          card.dataset.person,
          card.dataset.case,
          card.dataset.title,
          card.dataset.text,
        ].join(" ");
        const matchesQuery = query.length === 0 || haystack.includes(query);
        const matchesCity = city.length === 0 || card.dataset.city === city;
        const isVisible = matchesQuery && matchesCity;

        card.hidden = !isVisible;
        shown += isVisible ? 1 : 0;
      }

      if (visibleCount) {
        visibleCount.textContent = String(shown);
      }
      if (emptyState instanceof HTMLElement) {
        emptyState.style.display = shown === 0 ? "block" : "none";
      }
    }

    function applySort() {
      if (!(sortOrder instanceof HTMLSelectElement) || !(list instanceof HTMLElement)) {
        return;
      }

      const sorted = [...cards].sort((a, b) => {
        if (!(a instanceof HTMLElement) || !(b instanceof HTMLElement)) {
          return 0;
        }

        if (sortOrder.value === "date-asc") {
          return String(a.dataset.date).localeCompare(String(b.dataset.date));
        }
        if (sortOrder.value === "person-asc") {
          return String(a.dataset.person).localeCompare(String(b.dataset.person), "ru");
        }
        return String(b.dataset.date).localeCompare(String(a.dataset.date));
      });

      list.replaceChildren(...sorted);
    }

    searchInput?.addEventListener("input", applyFilters);
    cityFilter?.addEventListener("change", applyFilters);
    sortOrder?.addEventListener("change", () => {
      applySort();
      applyFilters();
    });
  </script>
</BaseLayout>
