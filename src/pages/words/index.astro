---
import { getCollection } from "astro:content";
import { formatRussianTableDate } from "../../lib/dates";
import { toDisplayWord } from "../../lib/lastWords";
import { detectOriginalLanguage } from "../../lib/originalLanguages";
import { isRussianWord } from "../../lib/people";
import { buildTagDirectory, getTagHref, isRussianTag } from "../../lib/tags";
import BaseLayout from "../../layouts/BaseLayout.astro";

const finalWords = (await getCollection("last-words"))
    .map(toDisplayWord)
    .filter(isRussianWord)
    .sort((a, b) => a.person.localeCompare(b.person, "ru"));
const tagSlugs = Object.fromEntries(
    buildTagDirectory(finalWords).map((tag) => [tag.name, tag.slug]),
);
const countries = [
    ...new Set(finalWords.map((word) => word.country).filter(Boolean)),
].sort((a, b) => a.localeCompare(b, "ru"));
const periods = [
    ...new Set(finalWords.map((word) => word.period).filter(Boolean)),
].sort((a, b) => a.localeCompare(b, "ru"));
const tags = [...new Set(finalWords.flatMap((word) => word.tags))]
    .filter(isRussianTag)
    .sort((a, b) => a.localeCompare(b, "ru"));
const originalLanguagesBySlug = Object.fromEntries(
    finalWords.map((word) => {
        const detection = detectOriginalLanguage(word);
        return [
            word.slug,
            detection && detection.language !== word.language
                ? detection.languageLabel
                : "",
        ];
    }),
);

const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="База слов">
    <section class="section words-section" aria-label="Все последние слова">
        <div class="table-tools">
            <div class="table-tools-search">
                <input
                    id="words-search"
                    type="search"
                    placeholder="Поиск по имени, стране, эпохе или тегам"
                />
            </div>
            <div class="table-tools-filters">
                <select id="words-country">
                    <option value="">Все страны</option>
                    {countries.map((country) => <option value={country}>{country}</option>)}
                </select>
                <select id="words-period">
                    <option value="">Все эпохи</option>
                    {periods.map((period) => <option value={period}>{period}</option>)}
                </select>
                <select id="words-tag">
                    <option value="">Все теги</option>
                    {tags.map((tag) => <option value={tag}>{tag}</option>)}
                </select>
            </div>
            <div class="table-tools-meta">
                <p class="meta">
                    <span id="words-count">{finalWords.length}</span> из {
                        finalWords.length
                    } записей
                </p>
                <button class="reset-table" id="words-reset" type="button"
                    >Сбросить</button
                >
            </div>
        </div>
        <div class="words-table-wrap">
            <table class="words-table" id="words-table">
                <thead>
                    <tr>
                        <th
                            class="is-sorted"
                            data-sort-header="0"
                            aria-sort="ascending"
                        >
                            <button type="button" data-sort-column="0"
                                >Имя</button
                            >
                        </th>
                        <th data-sort-header="1" aria-sort="none">
                            <button type="button" data-sort-column="1"
                                >Дата слова</button
                            >
                        </th>
                        <th data-sort-header="2" aria-sort="none">
                            <button type="button" data-sort-column="2"
                                >Страна</button
                            >
                        </th>
                        <th data-sort-header="3" aria-sort="none">
                            <button type="button" data-sort-column="3"
                                >Язык оригинала</button
                            >
                        </th>
                        <th data-sort-header="4" aria-sort="none">
                            <button type="button" data-sort-column="4"
                                >Теги</button
                            >
                        </th>
                    </tr>
                </thead>
                <tbody>
                    {
                        finalWords.map((word) => (
                            <tr
                                data-country={word.country ?? ""}
                                data-period={word.period ?? ""}
                                data-tags={word.tags.join("|")}
                                data-has-photo={word.featuredImage ? "true" : "false"}
                            >
                                <td class="word-name-cell">
                                    <a href={`${base}words/${word.slug}/`}>
                                        {word.title}
                                    </a>
                                </td>
                                <td class="word-statement-date-cell" data-sort-value={word.statementDate ?? ""}>
                                    {
                                        word.statementDate && (
                                            <time datetime={word.statementDate}>
                                                {formatRussianTableDate(word.statementDate)}
                                            </time>
                                        )
                                    }
                                </td>
                                <td class="word-country-cell">
                                    {word.country ?? ""}
                                </td>
                                <td class="word-original-language-cell">
                                    {originalLanguagesBySlug[word.slug]}
                                </td>
                                <td>
                                    {[...word.tags]
                                        .sort((a, b) =>
                                            a.localeCompare(b, "ru"),
                                        )
                                        .map((tag, index, tags) => (
                                            <>
                                                <a
                                                    class="word-tag-link"
                                                    href={getTagHref(base, tagSlugs[tag] ?? "tag")}
                                                >
                                                    {tag}
                                                </a>
                                                {index < tags.length - 1 && ", "}
                                            </>
                                        ))}
                                </td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </section>

    <script>
        const searchInput = document.querySelector("#words-search");
        const countrySelect = document.querySelector("#words-country");
        const periodSelect = document.querySelector("#words-period");
        const tagSelect = document.querySelector("#words-tag");
        const resetButton = document.querySelector("#words-reset");
        const countNode = document.querySelector("#words-count");
        const table = document.querySelector("#words-table");
        const tbody = table?.querySelector("tbody");
        const rows = tbody ? Array.from(tbody.querySelectorAll("tr")) : [];
        const storageKey = "final-statement.words-table";
        const sortState = {
            column: 0,
            direction: "asc",
        };

        function getCellText(row, columnIndex) {
            const cell = row.children[columnIndex];

            if (!(cell instanceof HTMLElement)) {
                return "";
            }

            return cell.dataset.sortValue ?? cell.textContent?.trim() ?? "";
        }

        function applyFilters() {
            if (!(searchInput instanceof HTMLInputElement)) {
                return;
            }

            const query = searchInput.value.trim().toLowerCase();
            const selectedCountry =
                countrySelect instanceof HTMLSelectElement
                    ? countrySelect.value
                    : "";
            const selectedPeriod =
                periodSelect instanceof HTMLSelectElement
                    ? periodSelect.value
                    : "";
            const selectedTag =
                tagSelect instanceof HTMLSelectElement ? tagSelect.value : "";
            let visibleCount = 0;

            for (const row of rows) {
                const text = `${row.textContent ?? ""} ${row.dataset.period ?? ""}`.toLowerCase();
                const rowTags = (row.dataset.tags ?? "").split("|").filter(Boolean);
                const matchesSearch = query.length === 0 || text.includes(query);
                const matchesCountry =
                    !selectedCountry ||
                    (row.dataset.country ?? "") === selectedCountry;
                const matchesPeriod =
                    !selectedPeriod ||
                    (row.dataset.period ?? "") === selectedPeriod;
                const matchesTag =
                    !selectedTag || rowTags.includes(selectedTag);
                const isVisible =
                    matchesSearch &&
                    matchesCountry &&
                    matchesPeriod &&
                    matchesTag;
                row.hidden = !isVisible;
                visibleCount += isVisible ? 1 : 0;
            }

            if (countNode) {
                countNode.textContent = String(visibleCount);
            }
        }

        function saveState() {
            if (!(searchInput instanceof HTMLInputElement)) {
                return;
            }

            window.localStorage.setItem(
                storageKey,
                JSON.stringify({
                    search: searchInput.value,
                    country:
                        countrySelect instanceof HTMLSelectElement
                            ? countrySelect.value
                            : "",
                    period:
                        periodSelect instanceof HTMLSelectElement
                            ? periodSelect.value
                            : "",
                    tag:
                        tagSelect instanceof HTMLSelectElement
                            ? tagSelect.value
                            : "",
                    sortColumn: sortState.column,
                    sortDirection: sortState.direction,
                }),
            );
        }

        function readState() {
            const rawState = window.localStorage.getItem(storageKey);

            if (!rawState) {
                return;
            }

            try {
                const savedState = JSON.parse(rawState);
                const savedColumn = Number(savedState.sortColumn);
                const savedDirection =
                    savedState.sortDirection === "desc" ? "desc" : "asc";

                if (
                    Number.isInteger(savedColumn) &&
                    savedColumn >= 0 &&
                    savedColumn <= 4
                ) {
                    sortState.column = savedColumn;
                    sortState.direction = savedDirection;
                }

                if (
                    searchInput instanceof HTMLInputElement &&
                    typeof savedState.search === "string"
                ) {
                    searchInput.value = savedState.search;
                }

                if (
                    countrySelect instanceof HTMLSelectElement &&
                    typeof savedState.country === "string"
                ) {
                    countrySelect.value = savedState.country;
                }

                if (
                    periodSelect instanceof HTMLSelectElement &&
                    typeof savedState.period === "string"
                ) {
                    periodSelect.value = savedState.period;
                }

                if (
                    tagSelect instanceof HTMLSelectElement &&
                    typeof savedState.tag === "string"
                ) {
                    tagSelect.value = savedState.tag;
                }
            } catch {
                window.localStorage.removeItem(storageKey);
            }
        }

        function updateSortIndicators() {
            table?.querySelectorAll("[data-sort-header]").forEach((header) => {
                if (!(header instanceof HTMLTableCellElement)) {
                    return;
                }

                const isActive =
                    Number(header.dataset.sortHeader) === sortState.column;
                header.classList.toggle("is-sorted", isActive);
                header.dataset.sortDirection = isActive
                    ? sortState.direction
                    : "";
                header.setAttribute(
                    "aria-sort",
                    isActive
                        ? sortState.direction === "asc"
                            ? "ascending"
                            : "descending"
                        : "none",
                );
            });
        }

        function applySort() {
            if (!tbody) {
                return;
            }

            const direction = sortState.direction === "asc" ? 1 : -1;
            const sortedRows = [...rows].sort((a, b) => {
                return (
                    getCellText(a, sortState.column).localeCompare(
                        getCellText(b, sortState.column),
                        "ru",
                        {
                            numeric: true,
                            sensitivity: "base",
                        },
                    ) * direction
                );
            });

            tbody.replaceChildren(...sortedRows);
            updateSortIndicators();
        }

        function sortRows(columnIndex) {
            if (sortState.column === columnIndex) {
                sortState.direction =
                    sortState.direction === "asc" ? "desc" : "asc";
            } else {
                sortState.column = columnIndex;
                sortState.direction = "asc";
            }

            applySort();
            saveState();
            applyFilters();
        }

        function resetTable() {
            if (searchInput instanceof HTMLInputElement) {
                searchInput.value = "";
            }

            if (countrySelect instanceof HTMLSelectElement) {
                countrySelect.value = "";
            }

            if (periodSelect instanceof HTMLSelectElement) {
                periodSelect.value = "";
            }

            if (tagSelect instanceof HTMLSelectElement) {
                tagSelect.value = "";
            }

            sortState.column = 0;
            sortState.direction = "asc";
            window.localStorage.removeItem(storageKey);
            applySort();
            applyFilters();
        }

        readState();
        applySort();
        applyFilters();

        searchInput?.addEventListener("input", () => {
            applyFilters();
            saveState();
        });
        countrySelect?.addEventListener("change", () => {
            applyFilters();
            saveState();
        });
        periodSelect?.addEventListener("change", () => {
            applyFilters();
            saveState();
        });
        tagSelect?.addEventListener("change", () => {
            applyFilters();
            saveState();
        });
        resetButton?.addEventListener("click", resetTable);
        table?.querySelectorAll("[data-sort-column]").forEach((button) => {
            button.addEventListener("click", () => {
                if (!(button instanceof HTMLElement)) {
                    return;
                }

                sortRows(Number(button.dataset.sortColumn));
            });
        });
    </script>
</BaseLayout>

<style>
    .table-tools {
        display: grid;
        gap: 16px;
        margin-top: 24px;
    }

    .words-section {
        width: min(1280px, calc(100vw - 48px));
        margin-left: 50%;
        transform: translateX(-50%);
    }

    .table-tools-search {
        max-width: 520px;
    }

    .table-tools-search input {
        width: 100%;
    }

    .table-tools-search input,
    .table-tools-filters select {
        min-height: 38px;
        padding: 7px 18px 7px 10px;
    }

    .table-tools-filters select {
        -webkit-appearance: none;
        appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='18' height='18' viewBox='0 0 18 18' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4.5 6.75L9 11.25L13.5 6.75' stroke='%231f2523' stroke-width='1.7' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-position: right 18px center;
        background-repeat: no-repeat;
        background-size: 18px 18px;
        padding-right: 10px;
    }

    .table-tools-filters {
        display: grid;
        grid-template-columns: repeat(3, minmax(160px, 220px));
        gap: 12px;
    }

    .table-tools-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .reset-table {
        padding: 7px 10px;
        color: var(--text);
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 6px;
        font: inherit;
        font-size: 13px;
        cursor: pointer;
    }

    .reset-table:hover,
    .reset-table:focus-visible {
        color: var(--accent-strong);
        border-color: var(--accent);
    }

    .reset-table:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
    }

    .words-table-wrap {
        margin-top: 18px;
        overflow-x: auto;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
    }

    .words-table {
        width: 100%;
        min-width: 1040px;
        border-collapse: collapse;
        table-layout: auto;
    }

    .words-table th,
    .words-table td {
        padding: 12px 14px;
        border-bottom: 1px solid var(--line);
        text-align: left;
        vertical-align: top;
    }

    .words-table th {
        padding: 0;
        color: var(--muted);
        background: var(--surface-muted);
        font-size: 13px;
        font-weight: 700;
    }

    .words-table th button {
        display: flex;
        align-items: center;
        gap: 6px;
        width: 100%;
        padding: 12px 14px;
        color: inherit;
        background: transparent;
        border: 0;
        font: inherit;
        font-weight: 700;
        text-align: left;
        cursor: pointer;
    }

    .words-table th button::after {
        content: "↕";
        color: var(--muted);
        font-size: 12px;
        opacity: 0.65;
    }

    .words-table th button:hover,
    .words-table th button:focus-visible {
        color: var(--accent-strong);
    }

    .words-table th button:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: -2px;
    }

    .words-table th.is-sorted {
        color: var(--accent-strong);
        background: color-mix(in srgb, var(--accent) 12%, var(--surface-muted));
    }

    .words-table th.is-sorted button::after {
        content: "↑";
        color: var(--accent-strong);
        opacity: 1;
    }

    .words-table th.is-sorted[data-sort-direction="desc"] button::after {
        content: "↓";
    }

    .words-table tr:last-child td {
        border-bottom: 0;
    }

    .words-table td {
        color: var(--text);
        font-size: 14px;
    }

    .words-table a {
        color: var(--accent);
        font-weight: 700;
        text-underline-offset: 3px;
    }

    .words-table a:visited {
        color: var(--visited);
    }

    .words-table a.word-tag-link:visited {
        color: var(--accent);
    }

    .words-table a:hover {
        color: var(--accent);
        text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
    }

    .words-table a:visited:hover {
        color: var(--visited);
        text-decoration-color: color-mix(in srgb, var(--visited) 45%, transparent);
    }

    .words-table a.word-tag-link:visited:hover {
        color: var(--accent);
        text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
    }

    .word-name-cell,
    .word-country-cell,
    .word-original-language-cell,
    .word-statement-date-cell {
        white-space: nowrap;
    }

    .word-name-cell {
        width: 240px;
    }

    .word-country-cell {
        width: 88px;
    }

    .word-original-language-cell {
        width: 130px;
    }

    .word-statement-date-cell {
        width: 150px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    }

    @media (max-width: 720px) {
        .table-tools-search {
            max-width: none;
        }

        .table-tools-filters {
            grid-template-columns: 1fr;
        }

        .table-tools-meta {
            white-space: normal;
        }

        .words-section {
            width: 100%;
            margin-left: 0;
            transform: none;
        }
    }
</style>
