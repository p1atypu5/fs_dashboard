---
import wpExportMeta from "../data/wpExportMeta.json";

type Props = {
  title: string;
  description?: string;
};

const { title, description = "Readonly-зеркало последних слов и рабочие инструменты команды." } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const basePath = new URL(base, Astro.url.origin).pathname;
const basePathWithoutTrailingSlash = basePath.replace(/\/$/, "");
const currentPath = Astro.url.pathname;
const routePath =
  currentPath === basePathWithoutTrailingSlash || currentPath === basePath
    ? "/"
    : currentPath.startsWith(basePath)
      ? `/${currentPath.slice(basePath.length)}`.replace(/\/{2,}/g, "/")
      : currentPath;
const normalizedRoutePath = routePath.endsWith("/") ? routePath : `${routePath}/`;
const pageTitle = title === "Последнее слово" ? title : `${title} | Последнее слово`;
const freshnessDate = new Date(wpExportMeta.fetchedAt);
const freshnessTimeZone = wpExportMeta.timeZone || "UTC";
const freshnessLabel = new Intl.DateTimeFormat("ru-RU", {
  day: "numeric",
  month: "long",
  year: "numeric",
  hour: "2-digit",
  minute: "2-digit",
  second: "2-digit",
  timeZone: freshnessTimeZone,
  timeZoneName: "short",
}).format(freshnessDate);

const isHomeActive = normalizedRoutePath === "/";
const isWordsActive = normalizedRoutePath.startsWith("/words/");
const isReportsActive =
  normalizedRoutePath.startsWith("/reports/") || normalizedRoutePath.startsWith("/service/");
const isAboutActive = normalizedRoutePath.startsWith("/about/");
const reportLinks = [
  {
    id: "names",
    label: "Имена",
    href: `${base}reports/names/`,
  },
  {
    id: "tags",
    label: "Теги",
    href: `${base}reports/tags/`,
  },
  {
    id: "missing-fields",
    label: "Неполные поля",
    href: `${base}reports/missing-fields/`,
  },
  {
    id: "original-languages",
    label: "Языки оригинала",
    href: `${base}reports/original-languages/`,
  },
  {
    id: "images",
    label: "Изображения",
    href: `${base}service/images/`,
  },
];
const currentReportId = normalizedRoutePath.startsWith("/reports/names/")
  ? "names"
  : normalizedRoutePath.startsWith("/reports/tags/")
    ? "tags"
    : normalizedRoutePath.startsWith("/service/images/")
      ? "images"
      : normalizedRoutePath.startsWith("/reports/original-languages/")
        ? "original-languages"
        : normalizedRoutePath.startsWith("/reports/missing-fields/")
          ? "missing-fields"
          : "";
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-main">
        <a class:list={["brand", { "is-active": isHomeActive }]} href={base} aria-current={isHomeActive ? "page" : undefined}>Последнее слово</a>
        <nav aria-label="Основная навигация">
          <a class:list={{ "is-active": isWordsActive }} href={`${base}words/`} aria-current={isWordsActive ? "page" : undefined}>База слов</a>
          <a class:list={{ "is-active": isReportsActive }} href={`${base}reports/missing-fields/`} aria-current={isReportsActive ? "page" : undefined}>Отчеты</a>
          <a class:list={{ "is-active": isAboutActive }} href={`${base}about/`} aria-current={isAboutActive ? "page" : undefined}>О проекте</a>
        </nav>
      </div>
      <p class="data-freshness">
        База актуальна на <time datetime={wpExportMeta.fetchedAt}>{freshnessLabel}</time>
      </p>
    </header>
    {
      isReportsActive && (
        <div class="report-nav-wrap">
          <nav class="report-nav" aria-label="Страницы отчетов и справочников">
            {reportLinks.map((link) => (
              <a
                href={link.href}
                aria-current={link.id === currentReportId ? "page" : undefined}
              >
                {link.label}
              </a>
            ))}
          </nav>
        </div>
      )
    }
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f6f6f6;
    --surface: #ffffff;
    --surface-muted: #efede7;
    --text: #1f2523;
    --muted: #646d68;
    --line: #d9d5ca;
    --accent: #345bdc;
    --accent-strong: #2748b8;
    --visited: #9f1f50;
    --warning: #9b4f18;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scrollbar-gutter: stable;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    line-height: 1.55;
  }

  a {
    color: var(--accent);
    text-decoration-line: none;
    text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
    text-underline-offset: 3px;
  }

  a:hover {
    text-decoration-line: underline;
  }

  a:visited {
    color: var(--visited);
    text-decoration-color: color-mix(in srgb, var(--visited) 45%, transparent);
  }

  a:visited:hover {
    color: var(--visited);
    text-decoration-color: color-mix(in srgb, var(--visited) 45%, transparent);
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    max-width: 1180px;
    margin: 0 auto;
    padding: 22px 24px;
    border-bottom: 1px solid var(--line);
  }

  .header-main {
    display: flex;
    align-items: center;
    gap: 24px;
    min-width: 0;
  }

  .brand {
    color: var(--text);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
  }

  .brand:visited {
    color: var(--text);
  }

  .brand:hover,
  .brand:visited:hover {
    color: var(--text);
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .brand,
  nav a {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    line-height: 1.2;
  }

  nav a {
    color: var(--text);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
  }

  .site-header a.is-active {
    font-size: 18px;
    font-weight: 750;
  }

  nav a:visited {
    color: var(--text);
  }

  nav a:hover,
  nav a:visited:hover {
    color: var(--muted);
    text-decoration: none;
  }

  .report-nav-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 8px 24px 0;
  }

  .report-nav {
    gap: 14px;
    min-height: 20px;
  }

  .report-nav a {
    color: var(--text);
    min-height: 20px;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
  }

  .report-nav a:visited {
    color: var(--text);
  }

  .report-nav a:hover,
  .report-nav a:visited:hover {
    color: var(--muted);
    text-decoration: none;
  }

  .report-nav a[aria-current="page"] {
    font-weight: 750;
  }

  .data-freshness {
    margin: 0;
    color: var(--muted);
    font-size: 12px;
    line-height: 1.25;
    text-align: right;
    white-space: nowrap;
  }

  main {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 24px 64px;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 820px;
    margin-bottom: 18px;
    font-size: clamp(36px, 6vw, 68px);
    line-height: 0.98;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 18px;
    font-size: 28px;
    line-height: 1.15;
  }

  .lead {
    max-width: 760px;
    color: var(--muted);
    font-size: 20px;
  }

  .section {
    margin-top: 44px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 30px;
  }

  .stat {
    min-height: 110px;
    padding: 18px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .stat strong {
    display: block;
    font-size: 30px;
    line-height: 1;
  }

  .stat span {
    display: block;
    margin-top: 10px;
    color: var(--muted);
    font-size: 14px;
  }

  .toolbar {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(160px, 240px) minmax(160px, 220px);
    gap: 12px;
    margin: 24px 0;
  }

  input,
  select {
    width: 100%;
    min-height: 44px;
    padding: 10px 12px;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    font: inherit;
  }

  .word-list {
    display: grid;
    gap: 12px;
  }

  .word-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: end;
    padding: 18px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    text-decoration: none;
  }

  .word-card h2,
  .word-card h3 {
    margin-bottom: 8px;
    color: var(--text);
    font-size: 20px;
  }

  .word-card p,
  .meta {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
  }

  .word-card > .meta {
    text-align: right;
  }

  .tag-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 4px 8px;
    color: var(--accent-strong);
    background: color-mix(in srgb, var(--accent) 12%, var(--surface));
    border-radius: 999px;
    font-size: 13px;
    text-decoration: none;
  }

  .tag:visited {
    color: var(--accent-strong);
  }

  .tag:hover {
    background: color-mix(in srgb, var(--accent) 20%, var(--surface));
    text-decoration: none;
  }

  .button-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 10px 14px;
    color: #ffffff;
    background: var(--accent);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
  }

  .button:visited {
    color: #ffffff;
  }

  .button:hover,
  .button:visited:hover {
    color: #ffffff;
    text-decoration: none;
  }

  .button.secondary {
    color: var(--accent);
    background: var(--surface);
    border: 2px solid var(--accent);
  }

  .button.secondary:visited {
    color: var(--accent);
    border-color: var(--accent);
  }

  .button.secondary:hover,
  .button.secondary:focus-visible,
  .button.secondary:visited:hover {
    color: var(--accent-strong);
    background: color-mix(in srgb, var(--accent) 8%, var(--surface));
    text-decoration: none;
  }

  .article {
    max-width: 820px;
  }

  .article-text {
    margin-top: 30px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    font-size: 19px;
    white-space: pre-wrap;
  }

  .empty-state {
    display: none;
    padding: 24px;
    color: var(--muted);
    background: var(--surface);
    border: 1px dashed var(--line);
    border-radius: 8px;
  }

  @media (max-width: 860px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .header-main {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
    }

    .data-freshness {
      text-align: left;
      white-space: normal;
    }

    .stats-grid,
    .toolbar {
      grid-template-columns: 1fr;
    }

    .word-card {
      grid-template-columns: 1fr;
    }

    .word-card > .meta {
      text-align: left;
    }
  }
</style>
