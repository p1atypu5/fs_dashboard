---
type Props = {
  title: string;
  description?: string;
};

const { title, description = "Readonly-зеркало последних слов и рабочие инструменты команды." } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const pageTitle = title === "Последнее слово" ? title : `${title} | Последнее слово`;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>Последнее слово</a>
      <nav aria-label="Основная навигация">
        <a href={`${base}words/`}>База слов</a>
        <a href={`${base}reports/missing-fields/`}>Отчеты</a>
        <a href={`${base}about/`}>О проекте</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f7f5f0;
    --surface: #ffffff;
    --surface-muted: #efede7;
    --text: #1f2523;
    --muted: #646d68;
    --line: #d9d5ca;
    --accent: #12605b;
    --accent-strong: #0a4743;
    --warning: #9b4f18;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    line-height: 1.55;
  }

  a {
    color: var(--accent);
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    max-width: 1180px;
    margin: 0 auto;
    padding: 22px 24px;
    border-bottom: 1px solid var(--line);
  }

  .brand {
    color: var(--text);
    font-size: 18px;
    font-weight: 750;
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  nav a {
    color: var(--muted);
    font-size: 15px;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--accent-strong);
  }

  main {
    max-width: 1180px;
    margin: 0 auto;
    padding: 36px 24px 64px;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 820px;
    margin-bottom: 18px;
    font-size: clamp(36px, 6vw, 68px);
    line-height: 0.98;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 18px;
    font-size: 28px;
    line-height: 1.15;
  }

  .lead {
    max-width: 760px;
    color: var(--muted);
    font-size: 20px;
  }

  .section {
    margin-top: 44px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 30px;
  }

  .stat {
    min-height: 110px;
    padding: 18px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .stat strong {
    display: block;
    font-size: 30px;
    line-height: 1;
  }

  .stat span {
    display: block;
    margin-top: 10px;
    color: var(--muted);
    font-size: 14px;
  }

  .toolbar {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(160px, 240px) minmax(160px, 220px);
    gap: 12px;
    margin: 24px 0;
  }

  input,
  select {
    width: 100%;
    min-height: 44px;
    padding: 10px 12px;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    font: inherit;
  }

  .word-list {
    display: grid;
    gap: 12px;
  }

  .word-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: end;
    padding: 18px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    text-decoration: none;
  }

  .word-card h2,
  .word-card h3 {
    margin-bottom: 8px;
    color: var(--text);
    font-size: 20px;
  }

  .word-card p,
  .meta {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
  }

  .word-card > .meta {
    text-align: right;
  }

  .tag-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .tag {
    padding: 4px 8px;
    color: var(--accent-strong);
    background: #dcebe8;
    border-radius: 999px;
    font-size: 13px;
  }

  .button-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 10px 14px;
    color: #ffffff;
    background: var(--accent);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
  }

  .button.secondary {
    color: var(--accent-strong);
    background: var(--surface-muted);
  }

  .article {
    max-width: 820px;
  }

  .article-text {
    margin-top: 30px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    font-size: 19px;
    white-space: pre-wrap;
  }

  .empty-state {
    display: none;
    padding: 24px;
    color: var(--muted);
    background: var(--surface);
    border: 1px dashed var(--line);
    border-radius: 8px;
  }

  @media (max-width: 860px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .stats-grid,
    .toolbar {
      grid-template-columns: 1fr;
    }

    .word-card {
      grid-template-columns: 1fr;
    }

    .word-card > .meta {
      text-align: left;
    }
  }
</style>
